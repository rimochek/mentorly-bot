BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=your_telegram_id

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=your_database_name
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password

# Для docker compose на VPS ничего ниже указывать не нужно —
# docker-compose.yml сам задаёт REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
